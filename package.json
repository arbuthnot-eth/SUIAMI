      "import": "./dist/verify.js",
      "types": "./dist/verify.d.ts"
    },
    "./roster": {
      "import": "./dist/roster.js",
      "types": "./dist/roster.d.ts"
    }
  },
  "files": [
    "dist",
    "contracts",
    "README.md"
  ],
  "scripts": {
